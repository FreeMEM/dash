# =============================================================================
# Main Program
# =============================================================================

Main
    # Open screen with 16 colors
    screen_open(4, "Blixel 0.3")

    # Create ReAction window
    ra_window_create("Blixel - Pixel Art Editor", 640, 500)

    # === ROW 1: Toolbar (weight=5 - small height) ===
    ra_layout_hgroup_weighted(5)
    ra_add_button(BTN_NEW, "New")
    ra_add_button(BTN_LOAD, "Load")
    ra_add_button(BTN_SAVE, "Save")
    ra_add_vspace()
    ra_add_button(BTN_PENCIL, "Pen")
    ra_add_button(BTN_ERASER, "Era")
    ra_add_button(BTN_LINE, "Lin")
    ra_add_button(BTN_RECT, "Rec")
    ra_add_button(BTN_FILL, "Fil")
    ra_add_button(BTN_EYEDROP, "Eye")
    ra_add_vspace()
    ra_add_button(BTN_CLEAR, "Clear")
    ra_layout_group_end_weighted()

    # === ROW 2: Main area (weight=80 - most of the space) ===
    ra_layout_hgroup_weighted(80)

    # Left column: Layer controls (weight=10)
    ra_layout_vgroup_weighted(10)
    ra_add_label("Layers")
    ra_add_button(BTN_LAYER_ADD, "+")
    ra_add_button(BTN_LAYER_DEL, "-")
    ra_add_button(BTN_LAYER_UP, "Up")
    ra_add_button(BTN_LAYER_DOWN, "Dn")
    ra_add_button(BTN_LAYER_MERGE, "Mrg")
    ra_add_label("Zoom")
    ra_add_slider(SLD_ZOOM, 2, 16, 6)
    ra_layout_group_end_weighted()

    # Center: Canvas area (Space gadget with weight=80)
    ra_add_drawing_area(GAD_CANVAS, 400, 400)

    # Right column: Color/palette (weight=10)
    ra_layout_vgroup_weighted(10)
    ra_add_label("Color")
    ra_add_slider(SLD_COLOR, 0, 15, 1)
    ra_layout_group_end_weighted()

    ra_layout_group_end_weighted()

    # === ROW 3: Timeline (weight=10) ===
    ra_layout_hgroup_weighted(10)
    ra_add_button(BTN_FRAME_PREV, "<")
    ra_add_button(BTN_FRAME_NEXT, ">")
    ra_add_button(BTN_FRAME_ADD, "+F")
    ra_add_button(BTN_FRAME_DEL, "-F")
    ra_add_button(BTN_FRAME_DUP, "Dup")
    ra_add_vspace()
    ra_add_button(BTN_PLAY, "Play")
    ra_add_button(BTN_STOP, "Stop")
    ra_layout_group_end_weighted()

    # Initialize layers and frames BEFORE opening window
    # (render hook needs data ready when window opens)
    if init_layers()
        Print "Layers initialized"
    else
        Print "Failed to initialize layers!"
    end

    if init_frames()
        Print "Frames initialized"
    else
        Print "Failed to initialize frames!"
    end

    # Open window
    ra_window_open()

    # Get RastPort for custom drawing
    ra_get_rastport()

    # Get canvas bounds from Space gadget AFTER window is open
    ra_get_drawing_bounds(GAD_CANVAS)
    canvas_x = ra_canvas_left()
    canvas_y = ra_canvas_top()
    canvas_area_w = ra_canvas_width()
    canvas_area_h = ra_canvas_height()

    # Setup palette colors
    gfx_rgb(0, 10, 10, 10)    # Gray (transparent indicator)
    gfx_rgb(1, 0, 0, 0)       # Black
    gfx_rgb(2, 15, 15, 15)    # White
    gfx_rgb(3, 6, 6, 8)       # Selection highlight
    gfx_rgb(4, 15, 0, 0)      # Red
    gfx_rgb(5, 0, 15, 0)      # Green
    gfx_rgb(6, 0, 0, 15)      # Blue
    gfx_rgb(7, 15, 15, 0)     # Yellow
    gfx_rgb(8, 15, 0, 15)     # Magenta
    gfx_rgb(9, 0, 15, 15)     # Cyan
    gfx_rgb(10, 15, 8, 0)     # Orange
    gfx_rgb(11, 8, 4, 0)      # Brown
    gfx_rgb(12, 15, 12, 12)   # Pink
    gfx_rgb(13, 0, 8, 0)      # Dark green
    gfx_rgb(14, 0, 0, 8)      # Dark blue
    gfx_rgb(15, 8, 0, 8)      # Purple

    # Initial draw of canvas
    draw_full_canvas()

    # State variables
    running = true
    prev_button = false

    # Main event loop
    while running
        event = ra_wait_event()

        # Handle window close
        if event == RA_EVENT_CLOSE()
            running = false
        end

        # Handle tool buttons
        if event == BTN_PENCIL
            current_tool = TOOL_PENCIL
            draw_tool_indicator()
        end
        if event == BTN_ERASER
            current_tool = TOOL_ERASER
            draw_tool_indicator()
        end
        if event == BTN_LINE
            current_tool = TOOL_LINE
            draw_tool_indicator()
        end
        if event == BTN_RECT
            current_tool = TOOL_RECT
            draw_tool_indicator()
        end
        if event == BTN_FILL
            current_tool = TOOL_FILL
            draw_tool_indicator()
        end
        if event == BTN_EYEDROP
            current_tool = TOOL_EYEDROP
            draw_tool_indicator()
        end

        # Handle file operations
        if event == BTN_NEW
            new_project()
            draw_full_canvas()
            draw_palette()
            draw_layer_panel()
            draw_timeline()
        end
        if event == BTN_LOAD
            if file_open_dialog("Load Blixel Project", "#?.blx")
                if load_project(file_fullpath())
                    draw_full_canvas()
                    draw_palette()
                    draw_layer_panel()
                    draw_timeline()
                    Print "Project loaded!"
                else
                    Print "Failed to load project!"
                end
            end
        end
        if event == BTN_SAVE
            if file_save_dialog("Save Blixel Project", "#?.blx")
                if save_project(file_fullpath())
                    Print "Project saved!"
                else
                    Print "Failed to save project!"
                end
            end
        end

        # Handle clear
        if event == BTN_CLEAR
            clear_current_layer()
            composite_layers()
            draw_full_canvas()
        end

        # Handle layer buttons
        if event == BTN_LAYER_ADD
            if add_layer()
                composite_layers()
                draw_full_canvas()
                draw_layer_panel()
            end
        end
        if event == BTN_LAYER_DEL
            if delete_layer()
                composite_layers()
                draw_full_canvas()
                draw_layer_panel()
            end
        end
        if event == BTN_LAYER_UP
            if move_layer_up()
                composite_layers()
                draw_full_canvas()
                draw_layer_panel()
            end
        end
        if event == BTN_LAYER_DOWN
            if move_layer_down()
                composite_layers()
                draw_full_canvas()
                draw_layer_panel()
            end
        end
        if event == BTN_LAYER_MERGE
            if merge_layer_down()
                composite_layers()
                draw_full_canvas()
                draw_layer_panel()
            end
        end

        # Handle frame/timeline buttons
        if event == BTN_FRAME_PREV
            stop_playback()
            prev_frame()
            draw_full_canvas()
            draw_timeline()
        end
        if event == BTN_FRAME_NEXT
            stop_playback()
            next_frame()
            draw_full_canvas()
            draw_timeline()
        end
        if event == BTN_FRAME_ADD
            stop_playback()
            if add_frame()
                draw_full_canvas()
                draw_timeline()
            end
        end
        if event == BTN_FRAME_DEL
            stop_playback()
            if delete_frame()
                draw_full_canvas()
                draw_timeline()
            end
        end
        if event == BTN_FRAME_DUP
            stop_playback()
            if duplicate_frame()
                draw_full_canvas()
                draw_timeline()
            end
        end
        if event == BTN_PLAY
            start_playback()
        end
        if event == BTN_STOP
            stop_playback()
        end

        # Handle sliders
        if event == SLD_COLOR
            current_color = ra_get_value(SLD_COLOR)
            draw_palette()
        end
        if event == SLD_ZOOM
            zoom_level = ra_get_value(SLD_ZOOM)
            composite_layers()
            draw_full_canvas()
            draw_palette()
            draw_layer_panel()
        end

        # Handle mouse input
        mx = mouse_x()
        my = mouse_y()
        button = mouse_button(0)

        clicked = false
        if button and not prev_button
            clicked = true
        end

        released = false
        if not button and prev_button
            released = true
        end

        # Layer panel, palette, and timeline are now handled by ReAction gadgets
        # Only canvas interactions need mouse handling

        # Handle canvas interactions
        if clicked and in_canvas(mx, my)
            drawing = true
            px = to_pixel_x(mx)
            py = to_pixel_y(my)
            start_x = px
            start_y = py
            last_x = px
            last_y = py

            if current_tool == TOOL_PENCIL
                plot_pixel(px, py, current_color)
            end
            if current_tool == TOOL_ERASER
                plot_pixel(px, py, TRANSPARENT)
            end
            if current_tool == TOOL_FILL
                flood_fill(px, py, current_color)
            end
            if current_tool == TOOL_EYEDROP
                current_color = get_composite_pixel(px, py)
                draw_palette()
                ra_set_value(SLD_COLOR, current_color)
            end
        end

        # Handle dragging
        if button and drawing and in_canvas(mx, my)
            px = to_pixel_x(mx)
            py = to_pixel_y(my)

            if current_tool == TOOL_PENCIL
                if px != last_x or py != last_y
                    draw_line_pixels(last_x, last_y, px, py, current_color)
                    last_x = px
                    last_y = py
                end
            end
            if current_tool == TOOL_ERASER
                if px != last_x or py != last_y
                    draw_line_pixels(last_x, last_y, px, py, TRANSPARENT)
                    last_x = px
                    last_y = py
                end
            end
        end

        # Handle release for shape tools
        if released and drawing
            drawing = false

            if in_canvas(mx, my)
                px = to_pixel_x(mx)
                py = to_pixel_y(my)

                if current_tool == TOOL_LINE
                    draw_line_pixels(start_x, start_y, px, py, current_color)
                end
                if current_tool == TOOL_RECT
                    draw_rect_outline(start_x, start_y, px, py, current_color)
                end
            end
        end

        # Update animation playback
        update_playback()

        prev_button = button
    end

    # Cleanup
    cleanup_frames()
    cleanup_layers()
    ra_window_close()
    screen_close()
end
