# =============================================================================
# Timeline Panel (handled by ReAction gadgets)
# =============================================================================

func draw_timeline()
    # Timeline is now ReAction buttons - no custom drawing needed
end

func draw_frame_thumb(frame_idx: Int)
    # No-op - frame display handled by ReAction
end

func handle_timeline_click(mx: Int, my: Int)
    # No-op - Timeline clicks handled by ReAction buttons
end

func update_playback()
    if not playing
        return
    end

    frame_counter = frame_counter + 1

    # Simple timing: advance frame every N iterations
    # At ~50 iterations/sec and 12 fps, that's about 4 iterations per frame
    frames_per_tick = 50 / anim_fps
    if frames_per_tick < 1
        frames_per_tick = 1
    end

    if frame_counter >= frames_per_tick
        frame_counter = 0

        # Advance to next frame
        new_frame = current_frame + 1
        if new_frame >= num_frames
            new_frame = 0
        end

        goto_frame(new_frame)
        draw_full_canvas()
        draw_timeline()
    end
end

func start_playback()
    if num_frames <= 1
        return
    end
    playing = true
    frame_counter = 0
end

func stop_playback()
    playing = false
end

