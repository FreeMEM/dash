# Test: 2D Arrays (Matrices)
# Tests nested array access: matrix[i][j]

Main
    Print "=== Matrix Test ==="

    # Create a 2D array (array of arrays)
    row1 = [1, 2, 3]
    row2 = [4, 5, 6]
    row3 = [7, 8, 9]

    # Access elements
    Print row1[0]
    Print row2[1]
    Print row3[2]

    # Modify elements
    row1[0] = 10
    row2[1] = 50
    Print row1[0]
    Print row2[1]

    # Simple 1D array test
    arr = [100, 200, 300]
    Print arr[0]
    Print arr[1]
    Print arr[2]

    arr[1] = 999
    Print arr[1]

    Print "=== Test Complete ==="
    Wait 2
end
