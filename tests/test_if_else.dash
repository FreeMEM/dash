# Test: If/Else Control Flow
# Verifica condicionales

Window TestWin
    title "If/Else Test"
    width 200
    height 100
end

Main
    x = 10

    # Simple if
    if x > 5
        result1 = 1
    end

    # If with else
    if x > 20
        result2 = 1
    else
        result2 = 0
    end

    # Nested if
    if x > 0
        if x < 100
            inRange = true
        end
    end

    # If with boolean
    flag = true
    if flag
        flagResult = 1
    end

    # If with not
    if not false
        notResult = 1
    end

    # If with and
    a = 5
    b = 10
    if a > 0 and b > 0
        bothPositive = true
    end

    # If with or
    if a > 100 or b > 5
        orResult = true
    end

    # Multiple conditions
    score = 75
    if score >= 90
        grade = 1
    else
        if score >= 80
            grade = 2
        else
            if score >= 70
                grade = 3
            else
                grade = 4
            end
        end
    end

    TestWin.open
    EventLoop
        On Close
            Stop
        end
    end
end
