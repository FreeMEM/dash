# Test the DOS file I/O module

import "lib/amiga/dos.dash"

Main
    Print "=== DOS Module Test ==="

    # Test file writing
    Print "Writing to test file..."
    fh = open_write("RAM:test.txt")
    if fh > 0
        write_line(fh, "Hello from Dash!")
        write_line(fh, "Line 2: Testing file I/O")
        write_line(fh, "Line 3: All done!")
        close_file(fh)
        Print "File written successfully!"
    else
        Print "Failed to open file for writing"
    end

    # Test file reading
    Print "Reading from test file..."
    fh = open_read("RAM:test.txt")
    if fh > 0
        Print "File contents:"
        for i in (1..3)
            line = read_line(fh)
            Print line
        end
        close_file(fh)
    else
        Print "Failed to open file for reading"
    end

    # Cleanup
    result = delete_file("RAM:test.txt")
    if result
        Print "Test file deleted."
    end

    Print "=== Test Complete ==="
    Wait 3
end
