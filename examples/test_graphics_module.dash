# Test the high-level graphics module

import "lib/amiga/graphics.dash"

Window win
    title "Graphics Module Demo"
    width 320
    height 200
end

Main
    win.open

    # Clear screen to black
    clear_with_color(0)

    # Draw some shapes with the convenience functions
    set_color(1)  # White
    draw_rect(10, 10, 100, 80)

    set_color(2)  # Color 2
    draw_fill_rect(120, 10, 80, 60)

    set_color(3)  # Color 3
    draw_line(10, 100, 300, 180)

    # Draw text
    set_color(1)
    draw_text(50, 150, "Dash Graphics!")

    # Draw circles
    set_color(2)
    draw_circle(250, 100, 30)

    # Animation loop demo
    x = 10
    for i in (1..100)
        # Erase old position
        erase_sprite(x, 170, 20, 10, 0)

        # Move
        x = x + 2
        if x > 290
            x = 10
        end

        # Draw new position
        draw_sprite(x, 170, 20, 10, 1)

        vsync()
    end

    Wait 3

    EventLoop
        On Close
            Stop
        end
    end
end
